{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV", "VERCEL", "VERCEL_ENV", "VERCEL_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".output/**", ".next/**", ".vercel/output/**"],
      "env": [
        "OPENAI_API_KEY",
        "REDIS_URL",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "ENCRYPTION_KEY",
        "SENDBLUE_API_KEY",
        "SENDBLUE_API_SECRET",
        "SENDBLUE_FROM_NUMBER",
        "SENDBLUE_WEBHOOK_SECRET",
        "NEXT_PUBLIC_PHONE_NUMBER",
        "USDA_API_KEY"
      ]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "dev:inspect": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {},
    "test": {},
    "clean": {
      "cache": false
    }
  }
}
